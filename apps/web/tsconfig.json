{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "module": "esnext",
    "paths": {
      "@prop-hunt/shared": [
        "../../packages/shared/src/index.ts"
      ]
    },
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true
  },
  "include": [
    "src",
    "next.config.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
